import numpy as np
import matplotlib.pyplot as plt
from scipy import signal
import os

# -------------------------
# LOAD DATA
# -------------------------
path = "data/sample_eeg.npy"

if os.path.exists(path):
    eeg = np.load(path)
    print("EEG cargado:", eeg.shape)
else:
    print("No hay dataset, generando sintético...")
    eeg = np.random.randn(8, 5000)

# -------------------------
# PLOT RAW SIGNAL
# -------------------------
plt.figure()
plt.title("Señales EEG (primeros canales)")
for i in range(min(4, eeg.shape[0])):
    plt.plot(eeg[i][:1000], label=f"Canal {i}")
plt.legend()
plt.show()

# -------------------------
# POWER SPECTRAL DENSITY
# -------------------------
fs = 250

plt.figure()
plt.title("Espectro de potencia (PSD)")

for i in range(min(4, eeg.shape[0])):
    freqs, psd = signal.welch(eeg[i], fs)
    plt.semilogy(freqs, psd, label=f"Canal {i}")

plt.xlabel("Frecuencia (Hz)")
plt.ylabel("PSD")
plt.legend()
plt.show()

# -------------------------
# BAND POWER VISUALIZATION
# -------------------------
def band_power(freqs, psd, band):
    low, high = band
    return np.mean(psd[(freqs >= low) & (freqs <= high)])

bands = {
    "theta": (4, 7),
    "alpha": (8, 12),
    "beta": (13, 30)
}

print("\nBand powers:")

for i in range(min(4, eeg.shape[0])):
    freqs, psd = signal.welch(eeg[i], fs)
    print(f"\nCanal {i}:")
    for band, rng in bands.items():
        print(f"  {band}: {band_power(freqs, psd, rng):.4f}")
